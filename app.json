{
  "name": "MAXX-XMD WhatsApp Bot",
  "description": "The most powerful WhatsApp multi-device bot with 580+ commands. Deploy in one click.",
  "keywords": [
    "whatsapp",
    "bot",
    "nodejs",
    "maxx-xmd"
  ],
  "website": "https://pair.maxxtech.co.ke",
  "repository": "https://github.com/Carlymaxx/maxxtechxmd",
  "logo": "https://files.catbox.moe/8jx0q3.jpg",
  "success_url": "/api/healthz",
  "scripts": {
    "postdeploy": "echo 'MAXX-XMD deployed successfully!'"
  },
  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp session ID. Get it from https://pair.maxxtech.co.ke",
      "required": false,
      "value": ""
    },
    "OWNER_NUMBER": {
      "description": "Your WhatsApp number with country code (e.g. 254700000000)",
      "required": false,
      "value": ""
    },
    "BOT_NAME": {
      "description": "Name for your bot",
      "required": false,
      "value": "MAXX-XMD"
    },
    "PREFIX": {
      "description": "Command prefix (e.g. . or ! or /)",
      "required": false,
      "value": "."
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}